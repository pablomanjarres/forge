{
  "name": "forge",
  "productName": "Forge",
  "private": true,
  "version": "0.1.0",
  "description": "AI orchestration center for media generation, agent management, and demo creation.",
  "author": "Pablo",
  "type": "module",
  "main": "electron-entry.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "preload:compile": "npx esbuild electron/preload.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist-electron/preload.js --external:electron",
    "dev:electron": "npm run preload:compile && concurrently \"vite\" \"tsx watch server/index.ts\" \"sleep 3 && electron .\"",
    "build": "tsc -b && vite build",
    "build:app": "node scripts/build-app.js && electron-builder --mac --dir && node scripts/verify-packaged-app.js \"dist-app/mac-arm64/Forge.app\"",
    "install:app": "npm run build:app && mkdir -p \"/Applications/Forge.app\" && ditto \"dist-app/mac-arm64/Forge.app\" \"/Applications/Forge.app\" && codesign --force --deep --sign - \"/Applications/Forge.app\" && node scripts/verify-packaged-app.js \"/Applications/Forge.app\" && echo 'Installed to /Applications'",
    "update:app": "npm run install:app",
    "verify:template-actions": "node scripts/verify-template-actions.js",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.pablo.forge",
    "productName": "Forge",
    "directories": {
      "output": "dist-app"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dir"
      ],
      "darkModeSupport": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "data/**/*",
      "build/trayTemplate.png",
      "build/trayTemplate@2x.png",
      "electron-entry.cjs"
    ],
    "extraResources": [
      {
        "from": "build/trayTemplate.png",
        "to": "build/trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "build/trayTemplate@2x.png"
      },
      {
        "from": "data",
        "to": "data"
      }
    ],
    "asar": false
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@google/genai": "^1.48.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "shadcn": "^4.1.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
